{% extends "base.html" %}
{% block title %}Portfólio de Vídeos — Flowers Films{% endblock %}
{% block content %}
<div class="page-hero">
  <div class="sec-tag">Portfólio</div>
  <h1>Produções em vídeo</h1>
</div>
<div class="grid-videos">
  {% if cfg.videos %}
    {% for v in cfg.videos %}
    <div class="video-card" style="aspect-ratio:16/9">
      
      <div class="video-overlay">
        <div class="play-btn"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 2l12 7-12 7V2z" fill="#fff"/></svg></div>
      </div>
      <div class="video-num">{{ '%02d' % loop.index }}</div>
    </div>
    {% endfor %}
  {% else %}
  <div class="empty-state" style="grid-column:1/-1">Nenhum vídeo cadastrado ainda.</div>
  {% endif %}
</div>
{% endblock %}
